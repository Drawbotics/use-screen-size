{
  "name": "@drawbotics/use-screen-size",
  "version": "3.0.2",
  "description": "Hook used to get the current screen size for responsive behaviour",
  "main": "lib/index.js",
  "author": "Nicolaos Moscholios <nick@drawbotics.com>",
  "license": "UNLICENSED",
  "scripts": {
    "clean": "rimraf lib/",
    "build": "NODE_ENV=production babel src --out-dir lib/",
    "test:watch": "BABEL_ENV=test jest --watch",
    "prepublishOnly": "npm run clean && npm test && npm run build",
    "test": "jest"
  },
  "jest": {
    "testEnvironment": "jsdom"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drawbotics/use-screen-size.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com/"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx}": "eslint --format node_modules/eslint-formatter-pretty/index.js --max-warnings=0"
  },
  "peerDependencies": {
    "@drawbotics/drylus-style-vars": ">=8.0.0",
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.6.0",
    "@babel/core": "^7.6.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-proposal-export-default-from": "^7.5.2",
    "@babel/preset-env": "^7.6.0",
    "@babel/preset-react": "^7.0.0",
    "@drawbotics/drylus-style-vars": "^8.0.0",
    "@eslint/js": "^10.0.1",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.3",
    "eslint-formatter-pretty": "^7.0.0",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^3.0.5",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^9.2.5",
    "react": "^16.9.0",
    "react-dom": "^16.9.0",
    "react-test-renderer": "^16.9.0"
  }
}
